# PostgreSQL — Neon (recommended) or local Docker Postgres.
#
# Copy to `.env.local` for Next.js. Plain `npx prisma` only loads `.env` from the project root
# (not `.env.local`). Prefer **`npm run db:migrate:deploy`** / **`npm run db:migrate`** so both
# files load and `DIRECT_URL` defaults to `DATABASE_URL` when unset (see `scripts/prisma-env.cjs`).
# If you insist on `npx prisma …` directly: put `DATABASE_URL` and `DIRECT_URL` in `.env`, or
# `export DIRECT_URL="$DATABASE_URL"` when using a single Postgres URL.
#
# Neon (dashboard → Connect): copy two URLs:
# - Pooled: host contains "-pooler" — use for DATABASE_URL (serverless / Vercel).
# - Direct: no "-pooler" — use for DIRECT_URL (Prisma migrate, introspection).
# Docs: https://neon.tech/docs/guides/prisma
#
# Local Docker (same value twice is fine):
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/picksix?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/picksix?schema=public"

DATABASE_URL=""
DIRECT_URL=""

# Auth.js — required in production (`AUTH_SECRET`). Generate: `openssl rand -base64 32`
# `AUTH_URL` / `NEXTAUTH_URL` — absolute site URL (e.g. http://localhost:3000 in dev, your Vercel URL in prod) for callbacks and cookies.
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"
# NEXTAUTH_URL="http://localhost:3000"

# Session length is code-configured (see src/lib/session-constants.ts) per UX rolling ~30-day policy.
# Optional — development only: positive integer seconds to shorten JWT `maxAge` for stale-session testing.
# Production ignores this. Example: SESSION_MAX_AGE_DEV_SECONDS="120"
# SESSION_MAX_AGE_DEV_SECONDS=

# --- NFL odds (Story 3.2) — server-only; never NEXT_PUBLIC_ ---
# The Odds API: https://the-odds-api.com/ (register for a key; mind free-tier quotas).
ODDS_API_KEY=""
# Optional: set to "true" to log the full raw JSON body from GET .../americanfootball_nfl/odds (verbose; server logs only).
# ODDS_API_DEBUG_LOG_RESPONSE=
# Optional: scripts/cron send `Authorization: Bearer <secret>` to POST /api/admin/nfl/snapshot-odds (and PATCH manual odds).
ODDS_SNAPSHOT_SECRET=""

# --- NFL schedule (Story 3.9) — API-Sports American Football; server-only; never NEXT_PUBLIC_ ---
# Dashboard key: https://api-sports.io/ — header `x-apisports-key`. Optional `API_SPORTS_HOST` defaults to `v1.american-football.api-sports.io` (direct). For RapidAPI subscribers set host to your RapidAPI host and use a RapidAPI key.
API_SPORTS_KEY=""
# API_SPORTS_HOST=

# --- Weather — OpenWeatherMap `/data/2.5/weather`; optional; server-only; never NEXT_PUBLIC_ ---
WEATHER_API_KEY=""

# --- Transactional email (Story 6.1) — Resend; server-only; never NEXT_PUBLIC_ ---
# Register at https://resend.com/ → API Keys. Domain verification required before sending to real recipients.
# See docs/email-provider-decision.md for setup prerequisites and free tier limits (3,000/month, 100/day).
RESEND_API_KEY=""
# Optional — local smoke tests only (see docs/email-local-smoke-test-runbook.md):
# Without a verified domain, use Resend sandbox sender and send only to your Resend account email.
# RESEND_FROM="Pick Six <onboarding@resend.dev>"

# Resend webhook signing secret — Resend dashboard → Webhooks → endpoint
RESEND_WEBHOOK_SECRET=""

# --- Vercel Cron (Story 6.5) — server-only; never NEXT_PUBLIC_ ---
# Vercel sends `Authorization: Bearer <CRON_SECRET>` on cron invocations. Generate: `openssl rand -hex 32`
# Set in Vercel project settings (Production + Preview) and in `.env.local` for local manual testing.
CRON_SECRET=""
