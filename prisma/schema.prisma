// Primary keys: `User.id` uses cuid(); reuse for future models (architecture.md).
// Email: normalize to lowercase in the app layer when Auth lands (Story 1.3).
//
// **Referential actions (league delete / FR61):**
// - Every row scoped to a **league** or **season** MUST use `onDelete: Cascade` on the FK to `League`
//   or `Season` so `League.delete` removes dependent data atomically (no orphan picks/schedules later).
// - **`User` → `LeagueMembership`:** `Cascade` so account deletion removes memberships without orphan rows.
// - **Global NFL rows (`Team`, `NflGame`):** no `League` FK — never cascade from `League` delete.
// - Prefer **Restrict** only if product explicitly blocks parent delete until children are removed (not
//   current MVP). Use **SetNull** only when the child row must survive without the parent (optional FK).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime? @map("email_verified") @db.Timestamptz
  passwordHash  String?   @map("password_hash")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  accounts          Account[]
  sessions          Session[]
  leagueMemberships LeagueMembership[]

  @@map("users")
}

enum LeagueMembershipRole {
  ADMIN
  MEMBER

  @@map("league_membership_role")
}

/// FR1 league container. **Name is globally unique** in MVP (one tenant namespace).
/// Children (`Season`, `LeagueMembership`, `Invitation`) use `onDelete: Cascade` from `League`.
model League {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  seasons     Season[]
  memberships LeagueMembership[]
  invitations Invitation[]

  @@map("leagues")
}

/// One row per league per NFL season year. **`first_competition_week`** (1–18) is the single
/// source of truth for when in-season competition starts for this league+season (Stories 2.1, 2.7; Epic 3+).
model Season {
  id       String @id @default(cuid())
  leagueId String @map("league_id")
  /// NFL season label year (see `getCurrentNflSeasonYear` in app layer).
  nflSeasonYear Int @map("nfl_season_year")
  /// First NFL regular season week when this league’s picks begin (1–18; default 1).
  firstCompetitionWeek Int @default(1) @map("first_competition_week")
  /// **FR3** (Story 2.3): when non-null, admin marked this season ready for weekly operations; Epic 3+ gates picks and automation on this flag.
  preSeasonInitializedAt DateTime? @map("pre_season_initialized_at") @db.Timestamptz
  /// **Story 2.7 / Epic 3:** when non-null, `first_competition_week` is immutable (first pick saved or competition-week deadline passed). Writers land in Epic 3.
  firstCompetitionWeekLockedAt DateTime? @map("first_competition_week_locked_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  picks Pick[]

  @@unique([leagueId, nflSeasonYear])
  @@map("seasons")
}

model LeagueMembership {
  id        String               @id @default(cuid())
  userId    String               @map("user_id")
  leagueId  String               @map("league_id")
  role      LeagueMembershipRole
  createdAt DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime             @updatedAt @map("updated_at") @db.Timestamptz

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  picks  Pick[]

  @@unique([userId, leagueId])
  @@map("league_memberships")
}

/// Canonical NFL franchise (global — not tied to a `League` row).
model Team {
  id           String @id @default(cuid())
  abbreviation String @unique @map("abbreviation")
  name         String @map("name")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  homeGames NflGame[] @relation("NflGameHomeTeam")
  awayGames NflGame[] @relation("NflGameAwayTeam")
  picks     Pick[]

  @@map("teams")
}

/// NFL regular-season game (global — keyed by `nfl_season_year`, not `Season.id`).
model NflGame {
  id            String   @id @default(cuid())
  nflSeasonYear Int      @map("nfl_season_year")
  weekNumber    Int      @map("week_number")
  homeTeamId    String   @map("home_team_id")
  awayTeamId    String   @map("away_team_id")
  kickoffAt     DateTime @map("kickoff_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  homeTeam Team @relation("NflGameHomeTeam", fields: [homeTeamId], references: [id], onDelete: Restrict)
  awayTeam Team @relation("NflGameAwayTeam", fields: [awayTeamId], references: [id], onDelete: Restrict)

  @@index([nflSeasonYear, weekNumber])
  @@map("nfl_games")
}

/// One saved pick per membership per NFL week per `Season` (Epic 3). Writers for `first_competition_week_locked_at` land in Stories 3.4 / 3.5.
model Pick {
  id                 String @id @default(cuid())
  seasonId           String @map("season_id")
  leagueMembershipId String @map("league_membership_id")
  teamId             String @map("team_id")
  nflWeekNumber      Int    @map("nfl_week_number")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  season           Season           @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  leagueMembership LeagueMembership @relation(fields: [leagueMembershipId], references: [id], onDelete: Cascade)
  team             Team             @relation(fields: [teamId], references: [id], onDelete: Restrict)

  @@unique([leagueMembershipId, seasonId, nflWeekNumber])
  @@index([seasonId])
  @@map("picks")
}

// Auth.js Prisma adapter tables (NFR11). With Credentials + JWT session strategy, `Session` rows
// are unused until a provider supports database-backed sessions; see `src/lib/auth.ts`.
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime @db.Timestamptz
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime @db.Timestamptz

  @@unique([identifier, token])
  @@map("verification_tokens")
}

/// Single-use invitation for account creation (FR8). Raw token is never stored — only SHA-256 hash.
/// **`leagueId` null** — legacy dev seed / global invites (Story 1.5). **Set** — league-scoped admin invites (Story 2.2).
/// **DB partial unique** (migration `20260412140000_invitations_one_pending_per_league_email`): at most one
/// pending row per `(league_id, invited_email)` when `league_id` is set (not modeled in Prisma).
model Invitation {
  id           String    @id @default(cuid())
  leagueId     String?   @map("league_id")
  tokenHash    String    @unique @map("token_hash")
  invitedEmail String    @map("invited_email")
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz
  consumedAt   DateTime? @map("consumed_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  league League? @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@index([leagueId, invitedEmail])
  @@map("invitations")
}
