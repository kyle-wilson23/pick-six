// Primary keys: `User.id` uses cuid(); reuse for future models (architecture.md).
// Email: normalize to lowercase in the app layer when Auth lands (Story 1.3).
//
// **Referential actions (league delete / FR61):**
// - Every row scoped to a **league** or **season** MUST use `onDelete: Cascade` on the FK to `League`
//   or `Season` so `League.delete` removes dependent data atomically (no orphan picks/schedules later).
// - **`User` → `LeagueMembership`:** `Cascade` so account deletion removes memberships without orphan rows.
// - **Global NFL rows (`Team`, `NflGame`):** no `League` FK — never cascade from `League` delete.
// - Prefer **Restrict** only if product explicitly blocks parent delete until children are removed (not
//   current MVP). Use **SetNull** only when the child row must survive without the parent (optional FK).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime? @map("email_verified") @db.Timestamptz
  passwordHash  String?   @map("password_hash")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  accounts          Account[]
  sessions          Session[]
  leagueMemberships LeagueMembership[]

  @@map("users")
}

enum LeagueMembershipRole {
  ADMIN
  MEMBER

  @@map("league_membership_role")
}

/// FR1 league container. **Name is globally unique** in MVP (one tenant namespace).
/// Children (`Season`, `LeagueMembership`, `Invitation`) use `onDelete: Cascade` from `League`.
model League {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  seasons     Season[]
  memberships LeagueMembership[]
  invitations Invitation[]
  auditLogEntries AuditLogEntry[]

  @@map("leagues")
}

/// One row per league per NFL season year. **`first_competition_week`** (1–18) is the single
/// source of truth for when in-season competition starts for this league+season (Stories 2.1, 2.7; Epic 3+).
model Season {
  id                           String    @id @default(cuid())
  leagueId                     String    @map("league_id")
  /// NFL season label year (see `getCurrentNflSeasonYear` in app layer).
  nflSeasonYear                Int       @map("nfl_season_year")
  /// First NFL regular season week when this league’s picks begin (1–18; default 1).
  firstCompetitionWeek         Int       @default(1) @map("first_competition_week")
  /// **FR3** (Story 2.3): when non-null, admin marked this season ready for weekly operations; Epic 3+ gates picks and automation on this flag.
  preSeasonInitializedAt       DateTime? @map("pre_season_initialized_at") @db.Timestamptz
  /// **Story 2.7 / Epic 3:** when non-null, `first_competition_week` is immutable (first pick saved or competition-week deadline passed). Writers land in Epic 3.
  firstCompetitionWeekLockedAt DateTime? @map("first_competition_week_locked_at") @db.Timestamptz
  createdAt                    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  picks  Pick[]

  @@unique([leagueId, nflSeasonYear])
  @@map("seasons")
}

model LeagueMembership {
  id        String               @id @default(cuid())
  userId    String               @map("user_id")
  leagueId  String               @map("league_id")
  role      LeagueMembershipRole
  createdAt DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime             @updatedAt @map("updated_at") @db.Timestamptz

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  picks  Pick[]
  auditEntriesAsAdmin  AuditLogEntry[] @relation("AuditAdmin")
  auditEntriesAsTarget AuditLogEntry[] @relation("AuditTarget")

  @@unique([userId, leagueId])
  @@map("league_memberships")
}

/// Canonical NFL franchise (global — not tied to a `League` row).
model Team {
  id           String   @id @default(cuid())
  abbreviation String   @unique @map("abbreviation")
  name         String   @map("name")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  homeGames           NflGame[]           @relation("NflGameHomeTeam")
  awayGames           NflGame[]           @relation("NflGameAwayTeam")
  picks               Pick[]
  nflWeekJailedAsTeam NflWeekJailedTeam[]
  auditEntriesAsBefore AuditLogEntry[] @relation("AuditBeforeTeam")
  auditEntriesAsAfter  AuditLogEntry[] @relation("AuditAfterTeam")

  @@map("teams")
}

enum NflGameStatus {
  SCHEDULED
  IN_PROGRESS
  FINAL
  CANCELLED

  @@map("nfl_game_status")
}

/// NFL regular-season game (global — keyed by `nfl_season_year`, not `Season.id`).
model NflGame {
  id            String         @id @default(cuid())
  nflSeasonYear Int            @map("nfl_season_year")
  weekNumber    Int            @map("week_number")
  homeTeamId    String         @map("home_team_id")
  awayTeamId    String         @map("away_team_id")
  kickoffAt     DateTime       @map("kickoff_at") @db.Timestamptz
  status        NflGameStatus  @default(SCHEDULED) @map("status")
  homeScore     Int?           @map("home_score")
  awayScore     Int?           @map("away_score")
  finalizedAt   DateTime?      @map("finalized_at") @db.Timestamptz
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  homeTeam  Team              @relation("NflGameHomeTeam", fields: [homeTeamId], references: [id], onDelete: Restrict)
  awayTeam  Team              @relation("NflGameAwayTeam", fields: [awayTeamId], references: [id], onDelete: Restrict)
  oddsLines NflGameOddsLine[]

  /// Natural key for idempotent schedule upserts (Story 3.9). Stable `id` preserves `NflGameOddsLine` FKs on refresh.
  @@unique([nflSeasonYear, weekNumber, homeTeamId, awayTeamId])
  @@index([nflSeasonYear, weekNumber])
  @@index([nflSeasonYear, weekNumber, status])
  @@map("nfl_games")
}

enum OddsSnapshotStatus {
  PENDING
  COMPLETED
  FAILED

  @@map("odds_snapshot_status")
}

/// One fetch or manual correction run for a given NFL season week (Story 3.2). Reads use the latest
/// `COMPLETED` line **per game**, not only the latest run — so partial API matches and one-game
/// manual patches stay composable.
model OddsSnapshotRun {
  id            String             @id @default(cuid())
  nflSeasonYear Int                @map("nfl_season_year")
  weekNumber    Int                @map("week_number")
  status        OddsSnapshotStatus
  /// Provider id, e.g. `the_odds_api`, or `manual` for admin-entered lines.
  source        String             @map("source")
  errorMessage  String?            @map("error_message") @db.Text
  startedAt     DateTime           @default(now()) @map("started_at") @db.Timestamptz
  completedAt   DateTime?          @map("completed_at") @db.Timestamptz

  lines NflGameOddsLine[]

  @@index([nflSeasonYear, weekNumber, status])
  @@map("odds_snapshot_runs")
}

model NflGameOddsLine {
  id                    String   @id @default(cuid())
  nflGameId             String   @map("nfl_game_id")
  oddsSnapshotRunId     String   @map("odds_snapshot_run_id")
  homeMoneylineAmerican Int?     @map("home_moneyline_american")
  awayMoneylineAmerican Int?     @map("away_moneyline_american")
  /// Point spread from the **home** team’s perspective (negative = home favored). Provider h2h/spreads mapped in `lib/integrations`.
  homeSpreadPoints      Decimal? @map("home_spread_points") @db.Decimal(5, 1)

  nflGame         NflGame         @relation(fields: [nflGameId], references: [id], onDelete: Cascade)
  oddsSnapshotRun OddsSnapshotRun @relation(fields: [oddsSnapshotRunId], references: [id], onDelete: Cascade)

  @@unique([oddsSnapshotRunId, nflGameId])
  @@index([nflGameId])
  @@map("nfl_game_odds_lines")
}

/// Global NFL result: one row per **(NFL season year, week)** for the jailed franchise (Story 3.3; FR50–FR52).
/// Not league-scoped — all leagues use the same snapshot.
enum NflJailedResolutionMethod {
  MONEYLINE
  SPREAD
  RANDOM

  @@map("nfl_jailed_resolution_method")
}

model NflWeekJailedTeam {
  id                 String                    @id @default(cuid())
  nflSeasonYear      Int                       @map("nfl_season_year")
  weekNumber         Int                       @map("week_number")
  jailedTeamId       String                    @map("jailed_team_id")
  resolvedBy         NflJailedResolutionMethod @map("resolved_by")
  /// Present only when `resolvedBy` is RANDOM; hex string for audit (FR52).
  /// Enforced by DB CHECK `nfl_week_jailed_teams_random_seed_iff_random` — see migration SQL.
  randomSeed         String?                   @map("random_seed") @db.Text
  auditJson          Json                      @map("audit_json")
  computedAt         DateTime                  @default(now()) @map("computed_at") @db.Timestamptz
  oddsLineSourceNote String?                   @map("odds_line_source_note") @db.Text

  jailedTeam Team @relation(fields: [jailedTeamId], references: [id], onDelete: Restrict)

  @@unique([nflSeasonYear, weekNumber])
  @@index([jailedTeamId])
  @@map("nfl_week_jailed_teams")
}

/// One saved pick per membership per NFL week per `Season` (Epic 3). Writers for `first_competition_week_locked_at` land in Stories 3.4 / 3.5.
model Pick {
  id                 String   @id @default(cuid())
  seasonId           String   @map("season_id")
  leagueMembershipId String   @map("league_membership_id")
  teamId             String   @map("team_id")
  nflWeekNumber      Int      @map("nfl_week_number")
  /// **FR20 / FR54:** 2-point underdog when true and rules match; scoring is Epic 5.
  antiJailedBonus    Boolean  @default(false) @map("anti_jailed_bonus")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz

  season           Season           @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  leagueMembership LeagueMembership @relation(fields: [leagueMembershipId], references: [id], onDelete: Cascade)
  team             Team             @relation(fields: [teamId], references: [id], onDelete: Restrict)

  @@unique([leagueMembershipId, seasonId, nflWeekNumber])
  /// FR53: prevents the same team being picked in two different weeks by the same member in one season, even under concurrent requests.
  @@unique([leagueMembershipId, seasonId, teamId])
  @@index([seasonId])
  @@map("picks")
}

/// Immutable record of every admin pick override (Story 4.3; FR32, NFR14, NFR50).
/// Written in the same transaction as the pick upsert inside submitPickOnBehalf.
/// No UPDATE/DELETE endpoints exist — tamper-evidence at the application layer.
model AuditLogEntry {
  id                 String   @id @default(cuid())
  leagueId           String   @map("league_id")
  adminMembershipId  String   @map("admin_membership_id")
  targetMembershipId String   @map("target_membership_id")
  nflWeekNumber      Int      @map("nfl_week_number")
  /// Null if this override created the pick for the week (no prior pick existed)
  beforeTeamId       String?  @map("before_team_id")
  afterTeamId        String   @map("after_team_id")
  /// Null if this override created the pick (no prior pick existed)
  beforeAntiJailed   Boolean? @map("before_anti_jailed")
  afterAntiJailed    Boolean  @map("after_anti_jailed")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz

  league           League           @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  /// onDelete: Restrict — no member removal stories in MVP; prevents orphan audit rows
  adminMembership  LeagueMembership @relation("AuditAdmin", fields: [adminMembershipId], references: [id], onDelete: Restrict)
  targetMembership LeagueMembership @relation("AuditTarget", fields: [targetMembershipId], references: [id], onDelete: Restrict)
  /// Team relations — Restrict: team rows are global and never deleted in MVP
  beforeTeam       Team?            @relation("AuditBeforeTeam", fields: [beforeTeamId], references: [id], onDelete: Restrict)
  afterTeam        Team             @relation("AuditAfterTeam", fields: [afterTeamId], references: [id], onDelete: Restrict)

  @@index([leagueId, createdAt(sort: Desc)])
  @@map("audit_log_entries")
}

// Auth.js Prisma adapter tables (NFR11). With Credentials + JWT session strategy, `Session` rows
// are unused until a provider supports database-backed sessions; see `src/lib/auth.ts`.
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime @db.Timestamptz
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime @db.Timestamptz

  @@unique([identifier, token])
  @@map("verification_tokens")
}

/// Single-use invitation for account creation (FR8). Raw token is never stored — only SHA-256 hash.
/// **`leagueId` null** — legacy dev seed / global invites (Story 1.5). **Set** — league-scoped admin invites (Story 2.2).
/// **DB partial unique** (migration `20260412140000_invitations_one_pending_per_league_email`): at most one
/// pending row per `(league_id, invited_email)` when `league_id` is set (not modeled in Prisma).
model Invitation {
  id           String    @id @default(cuid())
  leagueId     String?   @map("league_id")
  tokenHash    String    @unique @map("token_hash")
  invitedEmail String    @map("invited_email")
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz
  consumedAt   DateTime? @map("consumed_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  league League? @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@index([leagueId, invitedEmail])
  @@map("invitations")
}
